{
  "$schema": "https://raw.githubusercontent.com/LazyPanda07/WebFramework/refs/heads/main/schemas/web_framework_config_schema.json",
  "WebServer": {
    "ip": "127.0.0.1",
    "port": 8080
  },
  "WebFramework": {
    "assetsPath": "assets",
    "templatesPath": "templates",
    "webServerType": "multiThreaded",
    "settingsPaths": [
       "web.json" 
    ],
    "loadSources": [
      "current"
    ],
    "defaultAssetsPath": "WebFrameworkAssets"
  },
  "Logging": {
    "usingLogging": false,
    "dateFormat": "DMY",
    "logFileSize": 134217728
  },
  "ThreadPoolServer": {
    "threadCount": 8
  }
}